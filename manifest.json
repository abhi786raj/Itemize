{
  "manifest_version": 3,
  "name": "Itemize",
  "version": "1.0.0",
  "description": "Analyze and save receipt data offline.",
  "permissions": ["storage", "tabs", "sidePanel"],
  "icons": {
    "16": "./assets/icon-16.png",
    "48": "./assets/icon-48.png",
    "128": "./assets/icon-128.png"
  },
  "action": {
    "default_title": "Itemize",
    "default_icon": {
      "16": "./assets/icon-16.png",
      "48": "./assets/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
